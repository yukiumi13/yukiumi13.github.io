---
// Slim HKUST-blue research banner: one tagline, low presence.
// Identity (name / title / links) lives in the Sidebar, so it's intentionally
// omitted here to avoid duplication.
---
<section
  class="relative w-full overflow-hidden bg-ust-blue"
  style="height: min(34vh, 260px); margin-top: -108px;"
>
  <!-- Subtle gold diagonal ambient (very faint, just breaks flatness) -->
  <div
    class="absolute inset-0 pointer-events-none opacity-30"
    style="background-image:
      radial-gradient(circle at 85% 15%, rgba(187,140,31,0.22) 0%, transparent 45%),
      linear-gradient(135deg, transparent 60%, rgba(212,163,41,0.10) 85%, transparent 100%);"
  ></div>

  <!-- HKUST brand gold accents -->
  <div class="absolute left-0 top-0 bottom-0 w-[4px] bg-ust-gold"></div>
  <div class="absolute right-0 bottom-0 h-[3px] w-1/3 bg-ust-gold"></div>

  <!-- Content: single research tagline -->
  <div class="relative h-full max-w-container mx-auto px-5 flex flex-col justify-end pb-9 pt-32">
    <p
      class="text-white font-light leading-[1.15] tracking-tight2 max-w-[44ch]"
      style="font-size: clamp(1.4rem, 3vw, 2.2rem);"
    >
      3D Vision <span class="text-ust-gold">&times;</span> Vision-Language Models
      <span class="block text-white/85">&mdash; toward spatially intelligent, embodied AI.</span>
    </p>
  </div>
</section>
