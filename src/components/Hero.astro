---
// Pure HKUST blue hero, simplified text.
---
<section
  class="relative w-full overflow-hidden bg-ust-blue"
  style="height: min(52vh, 440px); margin-top: -108px;"
>
  <!-- Subtle gold diagonal ambient (very faint, just breaks flatness) -->
  <div
    class="absolute inset-0 pointer-events-none opacity-30"
    style="background-image:
      radial-gradient(circle at 85% 15%, rgba(187,140,31,0.22) 0%, transparent 45%),
      linear-gradient(135deg, transparent 60%, rgba(212,163,41,0.10) 85%, transparent 100%);"
  ></div>

  <!-- HKUST brand gold accents -->
  <div class="absolute left-0 top-0 bottom-0 w-[4px] bg-ust-gold"></div>
  <div class="absolute right-0 bottom-0 h-[3px] w-1/3 bg-ust-gold"></div>

  <!-- Content -->
  <div class="relative h-full max-w-container mx-auto px-5 flex flex-col justify-end pb-14 pt-32">
    <h1
      class="text-white font-light leading-[1.02] tracking-tight2"
      style="font-size: clamp(2.6rem, 6.5vw, 4.5rem);"
    >
      Yang <span class="italic font-extralight text-white/80">(Marino)</span> Li
    </h1>
    <div class="mt-4 text-ust-gold text-[13px] uppercase tracking-[0.22em] font-semibold">
      PhD Student · Rutgers University
    </div>
  </div>
</section>
