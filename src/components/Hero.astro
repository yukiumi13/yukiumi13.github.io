---
// Slim HKUST-blue banner carrying the Rutgers shield crest (reversed/white).
// Identity (name / title / links) lives in the Sidebar; this band just holds
// the current-institution mark for a clean, low-key header.
---
<section
  class="relative w-full overflow-hidden bg-ust-blue"
  style="height: min(34vh, 260px); margin-top: -108px;"
>
  <!-- HKUST brand gold accents -->
  <div class="absolute left-0 top-0 bottom-0 w-[4px] bg-ust-gold"></div>
  <div class="absolute right-0 bottom-0 h-[3px] w-1/3 bg-ust-gold"></div>

  <!-- Content: Rutgers shield crest, reversed (white) -->
  <div class="relative h-full max-w-container mx-auto px-5 flex flex-col justify-end pb-9 pt-28">
    <img
      src="/images/rutgers-shield-white.png"
      alt="Rutgers University shield"
      class="w-auto self-start"
      style="height: clamp(52px, 8vw, 72px);"
    />
  </div>
</section>
