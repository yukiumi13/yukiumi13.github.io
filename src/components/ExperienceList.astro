---
import { experiences } from '../data/experiences';
---
<ol class="relative pl-20 sm:pl-24 mt-2">
  <!-- Vertical line: passes through the center of logo tiles (w-14 = 56px → center 28px from left of li) -->
  <div class="absolute left-[27px] sm:left-[31px] top-7 bottom-7 w-px bg-neutral-300 -z-0"></div>

  {experiences.map((e) => (
    <li class="relative pb-8 last:pb-0 reveal">
      <!-- Logo node: 56×56 white tile with halo matching section bg.
           Current experience gets a 2px gold border + soft glow. -->
      <div
        class={`absolute left-0 sm:left-1 top-0 w-14 h-14 rounded-md bg-white
                ring-[5px] ring-[#f4f4f4] flex items-center justify-center p-2
                ${e.current
                  ? 'border-2 border-ust-gold shadow-[0_0_0_1px_rgba(187,140,31,0.25),0_2px_10px_rgba(187,140,31,0.18)]'
                  : 'border border-neutral-200 shadow-[0_1px_3px_rgba(0,0,0,0.06)]'}`}
      >
        {e.image ? (
          <img src={e.image} alt={e.institution} class="max-w-full max-h-full object-contain" />
        ) : (
          <div class="w-2.5 h-2.5 rounded-full bg-ust-gold"></div>
        )}
      </div>

      <!-- Header row: institution + period -->
      <div class="flex flex-wrap items-baseline gap-x-3 gap-y-0.5">
        <h3 class="text-[1.05rem] font-semibold leading-snug">
          {e.institutionUrl ? (
            <a href={e.institutionUrl} class="text-ust-blue hover:text-ust-gold">
              {e.institution}
            </a>
          ) : (
            <span class="text-ust-blue">{e.institution}</span>
          )}
          {e.tag && (
            <span
              class="ml-2 inline-block align-middle text-[10px] font-semibold uppercase
                     tracking-[0.15em] px-2 py-[3px] rounded-[2px] bg-ust-gold text-white"
            >
              {e.tag}
            </span>
          )}
        </h3>
        <div class={`ml-auto text-[13px] whitespace-nowrap font-medium ${
          e.current ? 'text-ust-gold' : 'text-neutral-600'
        }`}>
          {e.period}
        </div>
      </div>

      <!-- Sub: role · group · location -->
      <div class="text-[14px] text-neutral-700 mt-1">
        <span class="font-medium">{e.role}</span>
        {e.group && <span class="text-neutral-500"> · {e.group}</span>}
        {e.location && <span class="text-neutral-500"> · {e.location}</span>}
      </div>

      <!-- Description -->
      {e.description && (
        <p class="text-[14px] text-neutral-600 mt-1.5 leading-relaxed">
          {e.description}
        </p>
      )}
    </li>
  ))}
</ol>
