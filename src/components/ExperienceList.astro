---
import { experiences } from '../data/experiences';
import LogoTile from './LogoTile.astro';
---
<ol class="relative list-none p-0 mt-2">
  <!-- Continuous vertical line through the center of the logo column -->
  <div
    class="absolute left-[58px] sm:left-[94px] top-12 bottom-12 w-[3px] bg-neutral-300 -z-0"
    aria-hidden="true"
  ></div>

  {experiences.map((e) => (
    <li class="grid grid-cols-[120px_minmax(0,1fr)] sm:grid-cols-[192px_minmax(0,1fr)] gap-4 sm:gap-5 mb-10 last:mb-0 reveal">
      <!-- Marker column: square icon on top, date stamp below. Column stays wide for date legibility.
           Current entry gets a framed tile; past entries are just the icon on the page background. -->
      <div class="flex flex-col items-center self-start">
        {e.image ? (
          <LogoTile
            src={e.image}
            alt={e.institution}
            current={e.current}
            imageClass={e.imageClass}
          />
        ) : (
          <div class="w-[48px] h-[48px] sm:w-[64px] sm:h-[64px] flex items-center justify-center">
            <div class="w-2.5 h-2.5 rounded-full bg-ust-gold"></div>
          </div>
        )}
        <div
          class={`mt-3 px-2 bg-white text-[11px] leading-tight text-center font-medium whitespace-nowrap ${
                  e.current ? 'text-ust-gold' : 'text-neutral-600'
                }`}
        >
          {e.period}
        </div>
      </div>

      <!-- Content column -->
      <div class="min-w-0 pt-0.5">
        <h3 class="text-[1.05rem] font-semibold leading-snug">
          {e.institutionUrl ? (
            <a href={e.institutionUrl} class="text-ust-blue hover:text-ust-gold">
              {e.institution}
            </a>
          ) : (
            <span class="text-ust-blue">{e.institution}</span>
          )}
          {e.tag && (
            <span
              class="ml-2 inline-block align-middle text-[10px] font-semibold uppercase
                     tracking-[0.15em] px-2 py-[3px] rounded-[2px] bg-ust-gold text-white"
            >
              {e.tag}
            </span>
          )}
        </h3>

        <div class="text-[14px] text-neutral-700 mt-1">
          <span class="font-medium">{e.role}</span>
          {e.group && <span class="text-neutral-500"> · {e.group}</span>}
          {e.location && <span class="text-neutral-500"> · {e.location}</span>}
        </div>

        {e.description && (
          <p class="text-[14px] text-neutral-600 mt-1.5 leading-relaxed">
            {e.description}
          </p>
        )}
      </div>
    </li>
  ))}
</ol>
