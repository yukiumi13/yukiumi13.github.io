---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Sidebar from '../components/Sidebar.astro';
import Section from '../components/Section.astro';
import NewsList from '../components/NewsList.astro';
import ExperienceList from '../components/ExperienceList.astro';
import Publication from '../components/Publication.astro';
import { publications } from '../data/publications';
import { awards, reviewerEntries, researchInterests } from '../data/awards';

// Set at build time; updated automatically on every CI deploy.
const lastUpdated = new Date().toLocaleString('en-US', { month: 'short', year: 'numeric' });
---

<Layout>
  <Navbar />
  <Hero />

  <div class="max-w-container mx-auto px-5 py-10">
    <div class="flex flex-col lg:flex-row gap-8">
      <Sidebar />

      <main class="flex-1 min-w-0" id="home">
        <Section title="Biography" id="biography">
          <p>
            I am a first-year PhD student at Rutgers University - New Brunswick.
            Fortunate to be advised by Prof. Chengzhi Mao, I am dedicated to
            bringing 3D Vision to the next stage, empowering it with spatial
            intelligence through Visual Language Models.
          </p>
          <p class="mt-3">
            I have been working on Generative AI for 3D Vision, involving
            generation, inverse rendering, and geometric reconstruction
            problems. I had wonderful experiences during my internships at
            LightSpeed Studio Tencent, Microsoft Research Asia, and SmartMore.
            It has been my honor to collaborate with talented researchers at
            these institutions, including
            <a class="text-ust-goldlight" href="https://johann.wang/"> Yuhan Wang</a>,
            <a class="text-ust-goldlight" href="https://jinnan-chen.github.io/"> Jinnan Chen</a>,
            <a class="text-ust-goldlight" href="https://www.microsoft.com/en-us/research/people/jinglwa/"> Jinglu Wang</a>,
            <a class="text-ust-goldlight" href="https://pableeto.netlify.app/"> Xiao Li</a>,
            <a class="text-ust-goldlight" href="https://andysonys.github.io/"> Shuai Yang</a> and
            <a class="text-ust-goldlight" href="https://sites.google.com/site/jiangbolu/"> Jiangbo Lu</a>.
          </p>
          <p class="mt-3">
            Previously, I received my M.Phil. degree in Artificial Intelligence
            from HKUST, under the supervision of
            <a class="text-ust-goldlight" href="https://www.yingcong.me/">Prof. Yingcong Chen</a> and
            <a class="text-ust-goldlight" href="https://www.danxurgb.net/">Prof. Dan Xu</a>, and
            obtained my B.S. degree in Mathematics from SYSU.
          </p>

          <aside
            class="mt-6 relative rounded-r-md border-l-[4px] border-l-ust-gold
                   bg-[#E7EFF8] pl-5 pr-6 py-5"
          >
            <div class="flex items-center gap-2 mb-2 text-ust-blue">
              <i class="fa-solid fa-bullhorn text-[13px]"></i>
              <span class="text-[11px] font-semibold uppercase tracking-[0.18em]">
                Open Positions · Recruiting Interns
              </span>
            </div>
            <p class="text-[15px] leading-relaxed text-neutral-800">
              <b>Our lab always recruits interns.</b> I primarily explore the synergy between
              <b>LLM reasoning agents</b> and <b>3D generative modeling</b>,
              advancing Embodied AI by empowering models with spatial
              intelligence to reason about and synthesize the 3D world in
              more sophisticated, human-like ways.
            </p>
            <a
              href="mailto:yang.marino.li@gmail.com"
              class="inline-flex items-center gap-1.5 mt-3 text-[14px] font-medium
                     text-ust-blue hover:text-ust-gold transition-colors"
            >
              Reach out via email
              <i class="fa-solid fa-arrow-right text-[11px]"></i>
            </a>
          </aside>
        </Section>

        <Section title="News" id="news">
          <NewsList />
        </Section>

        <Section title="Experience" id="experiences">
          <ExperienceList />
        </Section>

        <Section
          id="publications"
          title="Publications"
          titleHtml={`Publications <a class="text-ust-goldlight text-base" href="https://scholar.google.com/citations?user=kqrSHAYAAAAJ&hl=zh-CN">[Google Scholar]</a>`}
        >
          <p class="text-sm">*: Equal Contribution</p>
          {publications.map((p) => <Publication pub={p} />)}
        </Section>

        <Section title="Honors & Awards" id="awards">
          <table class="w-full border-separate" style="border-spacing: 2px;">
            <tbody>
              {awards.map((a) => (
                <tr>
                  <td class="py-1">{a.title}</td>
                  <td class="text-right whitespace-nowrap">{a.year}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </Section>

        <Section title="Professional Services" id="services">
          <h3 class="italic pl-2 text-lg font-semibold mt-2">Conference Reviewer:</h3>
          <table class="ml-2 mt-2" style="border-spacing: 2px;">
            <tbody>
              {reviewerEntries.map((r) => (
                <tr>
                  <td class="pr-6">{r.venue}</td>
                  <td>{r.years}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </Section>

        <Section title="Research Interests" id="interests">
          <ul class="pl-4 list-disc space-y-1">
            {researchInterests.map((i) => <li>{i}</li>)}
          </ul>
        </Section>

        <footer class="mt-20 mb-6 pt-6 border-t border-neutral-200">
          <div class="flex flex-col sm:flex-row items-center justify-between gap-3 text-[12px] text-neutral-500">
            <div>&copy; Yang Li · {new Date().getFullYear()}</div>
            <div class="flex items-center gap-3">
              <img
                src="https://hits.sh/yangmarino.li.svg?label=visitors&color=003c71&labelColor=525252&style=flat-square"
                alt="Visitor count"
                class="h-[18px]"
                loading="lazy"
              />
              <span class="text-neutral-300">·</span>
              <span>Last updated: {lastUpdated}</span>
            </div>
          </div>
          {/* Keep ClustrMaps tracking pixel alive so historical visitor data continues to accumulate. */}
          <img
            src="https://clustrmaps.com/map_v2.png?d=1PdlHW3BB8bDQVmfua3IVK_jlHWLkGp97VYU-t0h8nU&cl=ffffff&w=1"
            alt=""
            width="1"
            height="1"
            class="absolute opacity-0 pointer-events-none"
            aria-hidden="true"
          />
        </footer>
      </main>
    </div>
  </div>
</Layout>
